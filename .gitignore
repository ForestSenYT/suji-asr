# ============================================================
#  .gitignore — suji(中文讲课批量转写 · C++)
#  覆盖:VSCode / C++ CMake 构建 / 模型 / 媒体&输出 / Python / 密钥
# ============================================================

# ---------------- VSCode ----------------
# 默认忽略 .vscode 下的个人配置,保留可团队共享的几个
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
!.vscode/*.code-snippets
# 若想彻底不入库 .vscode:删掉上面 6 行,换成一行 ->  .vscode/
.history/
*.code-workspace

# clangd / IDE 缓存与生成的编译数据库
.cache/
.clangd/
compile_commands.json     # CMake 生成、clangd 本地用、可重生成;若要团队共享请删本行

# 其它 IDE(预留)
.idea/
.vs/
out/                      # VS 的 CMake 默认输出目录

# ---------------- C/C++ 构建产物 ----------------
build/
build-*/
cmake-build-*/
CMakeFiles/
CMakeCache.txt
cmake_install.cmake
CTestTestfile.cmake
install_manifest.txt
_deps/                    # CMake FetchContent 下载的依赖
CMakeUserPresets.json     # 个人 preset(团队的 CMakePresets.json 仍入库)

# 目标文件 / 库 / 可执行
*.o
*.obj
*.a
*.lib
*.so
*.so.*
*.dylib
*.dll
*.exe
*.out
*.app
# 预编译头 / 调试符号 / core dump
*.gch
*.pch
*.pdb
*.idb
*.dSYM/
/core
vgcore.*

# CUDA 中间产物
*.ptx
*.cubin
*.fatbin

# C++ 包管理(vcpkg / conan)
vcpkg_installed/
conanbuildinfo.*
conaninfo.txt
conan.lock

# ---------------- 模型(大文件,切勿入库;按需另行下载)----------------
models/
*.onnx
*.bin
*.gguf
*.ggml
*.tar.bz2
*.tar.gz
*.tgz
*.zip
tokens.txt                # 随模型下载,非源码
# 预编译 sherpa-onnx SDK / 解压目录
sherpa-onnx-*/
# 下载的 SDK / 工具(ffmpeg, cmake)/ CUDA·cuDNN redist 与 wheel(大二进制,另行下载,勿入库)
vendor/
*.whl

# ---------------- 媒体输入 & 转写输出(数据,切勿入库)----------------
# 讲课视频 / 音频(体积大)
*.mp4
*.mkv
*.mov
*.flv
*.avi
*.webm
*.ts
*.m4a
*.mp3
*.wav
*.flac
*.aac
*.ogg
*.opus
# 输出目录与字幕(.md/.json 不按扩展名忽略,避免误伤 README/配置 —— 统一放输出目录)
outputs/
output/
transcripts/
results/
*.srt
*.vtt
# 需要提交一个小测试样本时:  git add -f tests/data/sample.wav

# ---------------- Python(后处理 / ITN / CER 评测脚本)----------------
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
env/
ENV/
*.egg-info/
.eggs/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.ipynb_checkpoints/

# ---------------- 环境 / 密钥 ----------------
.env
.env.*
!.env.example
*.local

# ---------------- 日志 / 临时 ----------------
*.log
logs/
tmp/
.superpowers/             # subagent-driven-dev scratch (ledger / briefs / review diffs)
.tmp/
*.tmp
*.bak
*.swp
*~
# 测试/CLI e2e 在工作目录写的临时产物
test_*_tmp.*
cli_e2e_out.*

# ---------------- 操作系统 / 编辑器杂物 ----------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini